# Apple Music Downloader Configuration
# Copy this file to .env and fill in your values
# The .env file is gitignored for security

# Wrapper (Decryption Server) Configuration
# Apple Music login credentials for wrapper
#
# REQUIRED on Apple Silicon (arm64) - wrapper exits immediately without credentials
# Optional on x86_64 Linux - wrapper can run without credentials but some features may not work
#
# First-time setup requires 2FA:
# 1. Start wrapper with credentials: ./wrapper.sh start
# 2. Check logs: docker logs apple-music-wrapper
# 3. When prompted, write 2FA code to: data/data/com.apple.android.music/files/2fa.txt
#    Example: echo -n 123456 > data/data/com.apple.android.music/files/2fa.txt
# 4. Session is cached in data/ - subsequent starts use cached session (no 2FA)
#
# To re-authenticate (session expired, credentials changed): ./wrapper.sh login
APPLE_MUSIC_USERNAME=
APPLE_MUSIC_PASSWORD=

# Wrapper host and ports (defaults shown)
APPLE_MUSIC_WRAPPER_HOST=127.0.0.1
APPLE_MUSIC_WRAPPER_PORT=10020
APPLE_MUSIC_WRAPPER_M3U8_PORT=20020
APPLE_MUSIC_WRAPPER_ACCOUNT_PORT=30020

# Optional: Media user token for lyrics and advanced features
# NOT required for basic ALAC downloads, but required for:
# - Lyrics (LRC, word-by-word, translations)
# - aac-lc format (lossy, lower quality - avoid if you want lossless)
# - MV downloads (music videos - not needed for audio-only)
#
# Format explanations:
# - aac-lc: Lossy audio format, lower quality than ALAC. Only needed if you specifically
#   want this format (not recommended for lossless audio collection).
# - MV: Music video files (video + audio). Much larger files, requires mp4decrypt.
#   Not needed if you only want lossless audio.
#
# Extract from browser cookies: Application -> Storage -> Cookies -> https://music.apple.com
# Find cookie named 'media-user-token'
APPLE_MUSIC_MEDIA_USER_TOKEN=

# Optional: Auto-wrapper behavior (equivalent to --auto-wrapper flag)
# Set to 'true' to automatically start wrapper if not running, and stop it
# if the script started it (after download completes)
# Default: false (wrapper should be managed manually or left running)
APPLE_MUSIC_AUTO_WRAPPER=false
